{
  "version": 2,
  "rewrites": [
    { "source": "/api/v1/admin/(.*)", "destination": "https://portraitpay-api-production.up.railway.app/api/v1/admin/$1" },
    { "source": "/api/v1/face/(.*)", "destination": "https://portraitpay-api-production.up.railway.app/api/v1/face/$1" }
  ],
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "devCommand": "npm run dev"
}