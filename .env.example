# ============================================================
# PortraitPay AI — Environment Variables
# ============================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/portraitpay"

# NextAuth
AUTH_SECRET="your-auth-secret-here-generate-with-openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# External Services
OPENAI_API_KEY=""

# ─── Email (SMTP) ─────────────────────────────────────────────
# 腾讯企业邮箱 / SMTP
SMTP_HOST="smtp.exmail.qq.com"
SMTP_PORT="465"
SMTP_USER="your-smtp-user@portraitpayai.com"
SMTP_PASS="your-smtp-password-or-auth-code"
EMAIL_FROM="contact@portraitpayai.com"
EMAIL_FROM_NAME="PortraitPay AI"
ADMIN_EMAIL="admin@portraitpayai.com"

# ─── AI Generation Platforms ─────────────────────────────────
RUNWAY_API_URL="https://api.runwayml.com/v1"
RUNWAY_API_KEY=""
MIDJOURNEY_API_URL="https://api.midjourney.com/v1"
MIDJOURNEY_API_KEY=""

# ─── Blockchain (Ethereum Sepolia) ───────────────────────────
ETHEREUM_SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
ETH_WALLET_PRIVATE_KEY="your-burner-wallet-private-key"
PORTRAIT_CERT_CONTRACT_ADDRESS="0xYourDeployedContractAddress"

# ─── Base Mainnet ───────────────────────────────────────────
BASE_MAINNET_RPC_URL="https://mainnet.base.org"
BASE_CHAIN_ID="8453"
LICENSING_CONTRACT_ADDRESS="0xYourLicensingContractAddress"

# ─── IPFS (Pinata) ────────────────────────────────────────────
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""
PINATA_JWT=""

# ─── S3 / R2 (Object Storage) ───────────────────────────────
AWS_S3_BUCKET="portraitpay-uploads"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_ENDPOINT=""

# ─── Stripe Payment ─────────────────────────────────────────
STRIPE_SECRET_KEY=""                # sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY=''          # pk_test_... or pk_live_...
STRIPE_WEBHOOK_SECRET=''           # whsec_... (from Stripe Dashboard)
STRIPE_CONNECT_CLIENT_ID=''        # For Stripe Connect (future)
# Set to true to use stub Stripe calls in development
STRIPE_STUB='true'

# ─── KYC — 第三方提供商 ─────────────────────────────────────
# 当前激活的提供商: aliyun | tencent | onfido | jumio
KYC_PROVIDER="aliyun"

# 开启桩模式（开发/演示用，设为 false 使用真实 API）
KYC_ALIYUN_STUB="true"
KYC_ALIYUN_AUTO_APPROVE="true"

# 阿里云实人认证
# 开通：https://help.aliyun.com/zh/face-verification/
KYC_ALIYUN_ACCESS_KEY_ID=""
KYC_ALIYUN_ACCESS_KEY_SECRET=""
KYC_ALIYUN_REGION="cn-shanghai"
KYC_ALIYUN_APP_ID=""            # 实人认证方案 ID
KYC_ALIYUN_WEBHOOK_SECRET=""     # Webhook 回调验签密钥

# 腾讯云人脸核身
KYC_TENCENT_STUB="true"
KYC_TENCENT_AUTO_APPROVE="true"
KYC_TENCENT_SECRET_ID=""
KYC_TENCENT_SECRET_KEY=""
KYC_TENCENT_REGION="ap-guangzhou"
KYC_TENCENT_APP_ID=""
KYC_TENCENT_WEBHOOK_SECRET=""

# Onfido (境外)
KYC_ONFIDO_API_KEY=""
KYC_ONFIDO_WEBHOOK_SECRET=""

# Jumio (境外)
KYC_JUMIO_API_KEY=""
KYC_JUMIO_SECRET=""
KYC_JUMIO_WEBHOOK_SECRET=""
