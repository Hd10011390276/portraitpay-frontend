# ============================================================
# PortraitPay AI — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in the values, OR set them
# directly in Vercel Dashboard → Settings → Environment Variables
#
# ⚠️  NEVER commit .env files with real credentials to GitHub
# ============================================================

# ─── Database (Neon PostgreSQL) ──────────────────────────────
# Create a free project at: https://neon.tech
# Then: Dashboard → Connection Details → Connection string
# Format: postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-123456.us-east-2.aws.neon.tech/portraitpay?sslmode=require"

# ─── Authentication (NextAuth v5) ─────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_generated_secret_using_openssl_rand_base64_32"
AUTH_URL="https://portraitpay.vercel.app"
NEXTAUTH_URL="https://portraitpay.vercel.app"

# ─── OAuth (Optional — for Google login) ──────────────────────
# Get credentials at: https://console.cloud.google.com/
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Stripe Payment ────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
# For production use sk_live_... and pk_live_...
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Get webhook secret from: Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."
# Set to "false" in production to enable real payments
STRIPE_STUB="false"

# ─── Blockchain (Ethereum Sepolia) ─────────────────────────────
# Get RPC URL from: https://www.infura.io/ or https://www.alchemy.com/
ETHEREUM_SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY"
# ⚠️  Use a BURNER wallet — never hold mainnet funds in this wallet
ETH_WALLET_PRIVATE_KEY="0x..."
PORTRAIT_CERT_CONTRACT_ADDRESS="0x..."

# ─── IPFS (Pinata) ─────────────────────────────────────────────
# Sign up at: https://pinata.cloud/
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""
PINATA_JWT=""

# ─── Object Storage (S3 / Cloudflare R2) ──────────────────────
# For R2: https://dash.cloudflare.com/ → R2
AWS_S3_BUCKET="portraitpay-uploads"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# For Cloudflare R2:
AWS_ENDPOINT="https://xxx.r2.cloudflarestorage.com"

# ─── KYC — Aliyun Real Person Verification ────────────────────
# Sign up: https://www.aliyun.com/product/face-verification
KYC_PROVIDER="aliyun"
# Set to "false" in production
KYC_ALIYUN_STUB="false"
KYC_ALIYUN_AUTO_APPROVE="false"
KYC_ALIYUN_ACCESS_KEY_ID=""
KYC_ALIYUN_ACCESS_KEY_SECRET=""
KYC_ALIYUN_REGION="cn-shanghai"
KYC_ALIYUN_APP_ID=""
KYC_ALIYUN_WEBHOOK_SECRET=""

# ─── AI / OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=""
