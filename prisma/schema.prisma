// ============================================================
// PortraitPay AI — Extended Schema
// Adds: Portrait model, enums, extended User, OTP fields
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum UserRole {
  USER
  ARTIST
  AGENCY
  ENTERPRISE
  CELEBRITY
  ADMIN
  VERIFIER
}

enum KYCStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum PortraitStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum AuthorizationStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
  REJECTED
}

enum TransactionType {
  LICENSE_PURCHASE
  LICENSE_RENEWAL
  ROYALTY_PAYOUT
  KYC_REFUND
  PLATFORM_FEE
  WITHDRAWAL
  SETTLEMENT
  PLATFORM_COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

enum ReportStatus {
  PENDING_REVIEW
  VALIDATED
  REJECTED
  SETTLED
  LEGAL_ACTION
}

enum InfringementType {
  UNAUTHORIZED_USE
  EXPIRED_LICENSE
  SCOPE_VIOLATION
  RESALE
  DEEPFAKE
}

enum CelebrityAppStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum LicenseType {
  EXCLUSIVE
  NON_EXCLUSIVE
  SEMI_EXCLUSIVE
  EDITORIAL
  PERSONAL
}

// ============================================================
// User
// ============================================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String?
  phone        String? @unique

  role           UserRole  @default(USER)
  kycStatus      KYCStatus @default(NOT_STARTED)
  kycProviderRef String?
  kycVerifiedAt  DateTime?
  kycExpiredAt   DateTime?

  walletAddress    String? @unique
  stripeCustomerId String?

  displayName String?
  bio         String?

  // OTP fields (for phone login)
  otpCode    String?
  otpExpires DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  portraits             Portrait[]
  authorizations        Authorization[]      @relation("AuthGranter")
  granteeAuthorizations Authorization[]      @relation("AuthGrantee")
  licenses              License[]
  transactions          Transaction[]
  infringementReports   InfringementReport[] @relation("ReportDefendant")
  myReports             InfringementReport[] @relation("ReportPlaintiff")
  kycLogs               KYCLog[]
  celebrityApplications CelebrityApplication[]

  // Revenue & Settlement
  withdrawals Withdrawal[]
  settlements Settlement[]
  auditLogs   AuditLog[]   @relation("AuditAdmin")

  // Infringement monitoring config (one per user)
  monitorConfig InfringementMonitorConfig?

  // NextAuth
  accounts        Account[]
  sessions        Session[]
  name            String?
  image           String?
  emailVerified   DateTime?
  notifications   Notification[]
  userAuditLogs   UserAuditLog[]
  apiKeys         ApiKey[]
  aicontents      AIContent[]
  ipregistrations IPRegistration[]

  @@index([walletAddress])
  @@index([kycStatus])
}

// ============================================================
// Portrait
// ============================================================

model Portrait {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  title       String
  description String?
  category    String   @default("general")
  tags        String[] @default([])

  originalImageUrl String?
  thumbnailUrl     String?
  imageHash        String? @unique

  blockchainTxHash  String?   @unique
  blockchainNetwork String?   @default("sepolia")
  ipfsCid           String?
  certifiedAt       DateTime?

  status        PortraitStatus @default(DRAFT)
  faceEmbedding Float[]

  isPublic Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  authorizations Authorization[]
  licenses       License[]
  reports        InfringementReport[]

  @@index([ownerId])
  @@index([status])
  @@index([imageHash])
}

// ============================================================
// Authorization
// ============================================================

model Authorization {
  id String @id @default(cuid())

  portraitId String
  portrait   Portrait @relation(fields: [portraitId], references: [id])

  granterId String
  granteeId String
  grantee   User   @relation("AuthGrantee", fields: [granteeId], references: [id])
  granter   User   @relation("AuthGranter", fields: [granterId], references: [id])

  licenseType      LicenseType
  usageScope       String[]    @default([])
  exclusivity      Boolean     @default(false)
  territorialScope String      @default("global")

  startDate DateTime
  endDate   DateTime?

  licenseFee Decimal @db.Decimal(12, 2)
  currency   String  @default("USD")

  terms String @db.Text

  contractHash    String? @unique
  contractIpfsCid String?

  status AuthorizationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  licenses    License[]
  transaction Transaction?

  @@index([portraitId])
  @@index([granteeId])
  @@index([status])
}

// ============================================================
// Transaction
// ============================================================

model Transaction {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   TransactionType
  status TransactionStatus @default(PENDING)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("USD")

  authorizationId String?        @unique
  authorization   Authorization? @relation(fields: [authorizationId], references: [id])

  stripePaymentIntentId String? @unique
  stripeInvoiceId       String?

  royaltyRecipient String?
  royaltyPaid      Boolean @default(false)
  royaltyTxHash    String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
}

// ============================================================
// InfringementReport
// ============================================================

model InfringementReport {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportPlaintiff", fields: [reporterId], references: [id])

  defendantId String?
  defendant   User?   @relation("ReportDefendant", fields: [defendantId], references: [id])

  portraitId String
  portrait   Portrait @relation(fields: [portraitId], references: [id])

  type InfringementType

  // 侵权证据
  evidenceUrls     String[] @default([])
  evidenceHash     String? // 证据包 SHA-256 哈希
  originalImageUrl String?

  // 侵权描述
  description String    @db.Text
  detectedUrl String? // 发现侵权的 URL
  detectedAt  DateTime?

  status ReportStatus @default(PENDING_REVIEW)

  // 平台处理
  verifierId String?
  verifiedAt DateTime?
  resolution String?   @db.Text

  // 区块链存证
  reportHash    String? @unique
  reportIpfsCid String?

  // 举报来源：AUTO = 系统自动监测，MANUAL = 用户手动举报
  source String @default("MANUAL")

  // 相似度分数（系统自动监测时记录）
  similarityScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联的告警（系统监测产生）
  alertId String? @unique

  notices InfringementNotice[]

  @@index([portraitId])
  @@index([reporterId])
  @@index([status])
  @@index([source])
}

// ============================================================
// InfringementAlert — 系统自动监测产生的告警
// ============================================================

enum AlertStatus {
  PENDING // 待确认
  CONFIRMED // 确认侵权
  FALSE_POSITIVE // 误报
  EXPIRED // 超过确认时限自动关闭
}

model InfringementAlert {
  id String @id @default(cuid())

  portraitId String

  // 发现的侵权来源
  sourceUrl  String
  sourceName String // e.g. "Weibo", "Xiaohongshu", "Tiktok"
  sourceType String // "social_media" | "ai_platform" | "ecommerce" | "website"

  // 人脸比对结果
  similarityScore  Float // 0-1 相似度
  matchedEmbedding Float[] // 匹配到的人脸向量快照

  // 证据截图
  screenshotUrl  String?
  screenshotHash String? // 截图 SHA-256

  // 元数据
  pageTitle       String?
  pageDescription String?
  authorName      String? // 发布者名称
  publishedAt     DateTime? // 内容发布时间

  // 状态
  status AlertStatus @default(PENDING)

  // 所有者确认
  ownerId          String?
  ownerConfirmedAt DateTime?
  ownerDecision    String? // "CONFIRMED" | "FALSE_POSITIVE"

  // 转为举报后
  reportId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portraitId])
  @@index([status])
  @@index([sourceName])
}

// ============================================================
// InfringementMonitorConfig — 用户监测配置
// ============================================================

model InfringementMonitorConfig {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // 监测开关
  enabled Boolean @default(true)

  // 相似度阈值：默认 0.85 (85%)
  similarityThreshold Float @default(0.85)

  // 监测平台（留空表示全部）
  enabledPlatforms  String[] @default([])
  // 排除平台（白名单）
  excludedPlatforms String[] @default([])

  // 通知渠道
  notifyEmail  Boolean @default(true)
  notifySms    Boolean @default(false)
  notifyWechat Boolean @default(false)

  // 免打扰时段（UTC）
  quietHoursStart String? // "22:00"
  quietHoursEnd   String? // "08:00"

  // 高优先级（高相似度 > 0.95）不受免打扰限制
  highPriorityMuteExempt Boolean @default(true)

  // 扫描频率（小时）
  scanIntervalHours Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// InfringementNotice — 下架通知记录
// ============================================================

enum NoticeStatus {
  DRAFT // 草稿
  SENT // 已发送
  RECEIVED // 对方已收
  ACKNOWLEDGED // 对方已确认
  COMPLIED // 已下架
  REJECTED // 对方拒绝
  ESCALATED // 升级处理
}

enum NoticeType {
  TAKEDOWN // 下架通知
  WARNING // 警告函
  LEGAL // 律师函
}

model InfringementNotice {
  id String @id @default(cuid())

  reportId String
  report   InfringementReport @relation(fields: [reportId], references: [id])

  type NoticeType @default(TAKEDOWN)

  // 通知对象
  recipientName    String
  recipientEmail   String?
  recipientPhone   String?
  recipientAddress String? @db.Text // 邮寄地址

  // 通知内容（JSON 模板渲染结果）
  subject      String
  body         String  @db.Text
  renderedHtml String? @db.Text

  // 附件（PDF 版通知）
  attachmentUrl String?

  // 发送渠道
  channel String @default("EMAIL") // EMAIL | POST | API

  // 发送状态
  status NoticeStatus @default(DRAFT)

  // 发送时间
  sentAt DateTime?

  // 公证信息（预留）
  notarizationId   String? // 公证处 API 返回的 ID
  notarizationCert String? // 公证文书编号
  notarizedAt      DateTime?

  // 区块链存证
  noticeHash    String? @unique
  noticeIpfsCid String?

  // 对方回复
  responseReceivedAt DateTime?
  responseContent    String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([status])
}

// ============================================================
// EvidencePackage — 证据固化包（结构化证据）
// ============================================================

model EvidencePackage {
  id String @id @default(cuid())

  reportId String? @unique
  alertId  String? @unique

  // 证据类型
  evidenceType String // "screenshot" | "html_archive" | "api_response"

  // 证据内容/URL
  evidenceUrl String
  evidenceKey String? // S3 key (if stored)

  // 元数据
  capturedAt DateTime @default(now())
  capturedBy String   @default("SYSTEM") // SYSTEM | USER

  // SHA-256 哈希
  contentHash String @unique

  // 原始页面信息
  pageUrl         String?
  pageTitle       String?
  pageSnapshotUrl String? // Wayback Machine / 网页快照

  // IPFS 存证
  ipfsCid String?

  // 公证状态
  notarized      Boolean @default(false)
  notarizationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// KYCLog
// ============================================================

model KYCLog {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  provider    String
  externalRef String?
  action      String
  result      Json?

  // Additional KYC verification fields
  level          Int?
  idCardNumber   String?
  idCardName     String?
  idCardAddress  String?
  idCardExpire   DateTime?
  faceMatchScore Float?
  ocrRawData     Json?
  faceRawData    Json?
  rejectReason   String?
  verifierId     String?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================
// CelebrityApplication
// ============================================================

model CelebrityApplication {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  stageName       String
  realName        String
  idCardNumber    String
  idCardFrontUrl  String
  idCardBackUrl   String
  authLetterUrl   String
  authLetterHash  String?
  notaryCertUrl   String?

  agencyName    String?
  agencyContact String?
  agencyPhone   String?

  status CelebrityAppStatus @default(PENDING_REVIEW)

  reviewerId      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// License
// ============================================================

model License {
  id String @id @default(cuid())

  authorizationId String
  authorization   Authorization @relation(fields: [authorizationId], references: [id])

  portraitId String
  portrait   Portrait @relation(fields: [portraitId], references: [id])

  licenseeId String
  user       User   @relation(fields: [licenseeId], references: [id])

  startDate DateTime
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portraitId])
  @@index([licenseeId])
}

// ============================================================
// Enterprise
// ============================================================

enum EnterpriseStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Enterprise {
  id String @id @default(cuid())

  userId String @unique // 企业管理员账号

  // 营业执照信息
  companyName       String
  unifiedCreditCode String    @unique // 统一社会信用代码
  legalPersonName   String
  legalPersonIdCard String // 法人身份证号（加密存储）
  registeredCapital String? // 注册资本
  establishedDate   DateTime?
  businessTerm      String? // 营业期限
  businessScope     String?   @db.Text // 经营范围

  // 营业执照图片
  licenseImageUrl           String // 营业执照扫描件
  legalPersonIdCardFrontUrl String? // 法人身份证正面
  legalPersonIdCardBackUrl  String? // 法人身份证背面

  // 联系信息
  contactName  String
  contactPhone String
  contactEmail String

  // 审核信息
  status          EnterpriseStatus @default(PENDING)
  reviewerId      String?
  reviewedAt      DateTime?
  rejectionReason String?          @db.Text

  // 代理经纪公司
  isAgency         Boolean @default(false)
  agencyLicenseUrl String? // 经纪许可证

  // 有效期
  validUntil DateTime? // 认证有效期

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// Agency Artist Relation (经纪公司代理的艺人)
// ============================================================

model AgencyArtist {
  id String @id @default(cuid())

  agencyId String // 经纪公司 Enterprise.id
  artistId String // 艺人 User.id

  // 授权代理协议
  proxyAgreementUrl String? // 代理协议扫描件
  proxyStartDate    DateTime?
  proxyEndDate      DateTime?
  proxyStatus       String    @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, artistId])
  @@index([agencyId])
  @@index([artistId])
}

// ============================================================
// Enterprise Authorization Application
// ============================================================

enum EntAuthStatus {
  PENDING_PORTRAIT_OWNER
  PENDING_PLATFORM_REVIEW
  APPROVED
  REJECTED
  REVOKED
  EXPIRED
}

model EntAuthApplication {
  id String @id @default(cuid())

  enterpriseId String
  portraitId   String

  purpose          String   @db.Text
  usageScope       String[] @default([])
  exclusivity      Boolean  @default(false)
  territorialScope String   @default("global")
  usageDuration    Int

  proposedFee Decimal @db.Decimal(12, 2)
  currency    String  @default("CNY")

  status EntAuthStatus @default(PENDING_PORTRAIT_OWNER)

  portraitOwnerConfirmedAt DateTime?
  portraitOwnerConfirmed   Boolean   @default(false)

  platformReviewerId      String?
  platformReviewedAt      DateTime?
  platformRejectionReason String?   @db.Text

  authorizationId String? @unique

  contractHash    String? @unique
  contractIpfsCid String?

  certificateNo String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enterpriseId])
  @@index([portraitId])
  @@index([status])
}

// ============================================================
// AuthorizationCertificate
// ============================================================

model AuthorizationCertificate {
  id String @id @default(cuid())

  applicationId   String @unique
  authorizationId String @unique

  certificateNo String    @unique
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?

  pdfUrl String?

  blockchainTxHash  String?
  blockchainNetwork String?

  portraitOwnerSigned Boolean @default(false)
  enterpriseSigned    Boolean @default(false)
  platformSigned      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([certificateNo])
}

// ============================================================
// Withdrawal
// ============================================================

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

model Withdrawal {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("CNY")
  actualAmount Decimal? @db.Decimal(12, 2)
  exchangeRate Decimal? @db.Decimal(12, 4)

  bankName         String?
  bankAccount      String?
  bankAccountLast4 String?
  accountHolder    String?

  status          WithdrawalStatus @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?
  processedAt     DateTime?
  completedAt     DateTime?

  stripeTransferId String?
  stripePayoutId   String?

  settlementId String?
  settlement   Settlement? @relation(fields: [settlementId], references: [id])

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([settlementId])
}

// ============================================================
// Settlement
// ============================================================

enum SettlementStatus {
  PENDING
  CALCULATING
  COMPLETED
  CANCELLED
}

model Settlement {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  periodStart DateTime
  periodEnd   DateTime

  grossRevenue Decimal @db.Decimal(12, 2)
  platformFee  Decimal @db.Decimal(12, 2)
  netRevenue   Decimal @db.Decimal(12, 2)

  withdrawnAmount Decimal @default(0) @db.Decimal(12, 2)
  pendingAmount   Decimal @default(0) @db.Decimal(12, 2)
  availableAmount Decimal @default(0) @db.Decimal(12, 2)

  currency String           @default("CNY")
  status   SettlementStatus @default(PENDING)

  breakdown Json?

  settledAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  withdrawals Withdrawal[]

  @@index([userId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

// ============================================================
// AuditLog
// ============================================================

enum AuditAction {
  WITHDRAWAL_APPROVE
  WITHDRAWAL_REJECT
  SETTLEMENT_GENERATE
  SETTLEMENT_APPROVE
  USER_BALANCE_ADJUST
  TRANSACTION_FLAG
}

model AuditLog {
  id String @id @default(cuid())

  adminId    String
  admin      User        @relation("AuditAdmin", fields: [adminId], references: [id])
  targetType String
  targetId   String
  action     AuditAction
  before     Json?
  after      Json?
  reason     String?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
}

// ============================================================
// Notification
// ============================================================

enum NotificationType {
  SYSTEM
  AUTHORIZATION
  EARNING
  INFRINGEMENT
  KYC
  SETTLEMENT
  WITHDRAWAL
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType @default(SYSTEM)
  title String
  body  String           @db.Text
  data  Json? // { portraitId, authorizationId, reportId, etc. }

  isRead Boolean   @default(false)
  readAt DateTime?

  // Push channel
  channel String @default("IN_APP") // IN_APP | WEBSOCKET | EMAIL | SMS

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============================================================
// UserAuditLog — User-side operation audit trail
// ============================================================

enum UserAuditAction {
  // Auth
  LOGIN
  LOGIN_FAILED
  LOGOUT
  OTP_SENT
  OTP_VERIFIED
  OTP_FAILED
  // Profile
  PROFILE_UPDATE
  PHONE_BIND
  PHONE_UNBIND
  WALLET_BIND
  WALLET_UNBIND
  // KYC
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  KYC_EXPIRED
  // Portrait
  PORTRAIT_REGISTERED
  PORTRAIT_UPDATED
  PORTRAIT_SUSPENDED
  PORTRAIT_DELETED
  // Authorization
  AUTH_REQUEST_SENT
  AUTH_APPROVED
  AUTH_REJECTED
  AUTH_REVOKED
  AUTH_CERTIFICATE_DOWNLOADED
  // Earnings
  EARNINGS_WITHDRAWN
  EARNINGS_EXPORTED
  SETTLEMENT_VIEWED
  // Settings
  NOTIFICATION_SETTINGS_UPDATED
  MONITOR_CONFIG_UPDATED
  // API Key
  API_KEY_CREATED
  API_KEY_DELETED
  API_KEY_ROTATED
}

model UserAuditLog {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    UserAuditAction
  ipAddress String?
  userAgent String?

  // Target of the action (for context)
  targetType String? // "Portrait" | "Authorization" | "Withdrawal" | "ApiKey" | etc.
  targetId   String?

  // Result
  success Boolean @default(true)
  detail  String? @db.Text // human-readable description
  meta    Json? // extra context: { deviceType, browser, os, errorCode, etc. }

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, action])
  @@index([action, createdAt])
}

// ============================================================
// ApiKey — Third-party developer API keys
// ============================================================

enum ApiKeyStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

model ApiKey {
  id String @id @default(cuid())

  name String // e.g. "Production App", "Test Key"

  // Hashed key (show once at creation, store hash)
  keyHash String @unique

  // Prefix shown to user for identification (e.g. "ppk_live_abc123")
  keyPrefix String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status ApiKeyStatus @default(ACTIVE)

  // Permissions scope
  scopes String[] @default([]) // "earnings:read" | "authorizations:read" | "portraits:read"

  // Rate limits
  rateLimitPerMinute Int @default(60)

  // Usage tracking
  lastUsedAt   DateTime?
  requestCount BigInt    @default(0)

  // Expiry
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([keyHash])
}

// ============================================================
// RateLimitRecord — API rate limit tracking
// ============================================================

model RateLimitRecord {
  id String @id @default(cuid())

  identifier   String // "api_key_<hash>" or "ip_<address>"
  windowStart  DateTime
  requestCount Int      @default(1)

  @@unique([identifier, windowStart])
  @@index([identifier, windowStart])
}

// ============================================================
// NextAuth
// ============================================================

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// AI Content & IP Registration
// ============================================================

enum AIContentType {
  CHARACTER // AI-generated character/avatar
  ARTWORK // AI-generated artwork/illustration
  MUSIC // AI-generated music/audio
  TEXT // AI-generated text/content
  VIDEO // AI-generated video
  MODEL_3D // AI-generated 3D model
  OTHER
}

enum IPRegistrationStatus {
  DRAFT
  CERTIFIED // 版权已上链
  ACTIVE
  REVOKED
  EXPIRED
}

enum CertificateType {
  OWNERSHIP // 所有权证明
  LICENSE // 授权许可
  CREATION // 创作证明
  DERIVATIVE // 衍生作品证明
}

// AIContent: AI-generated content asset
model AIContent {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Content info
  title       String
  description String?       @db.Text
  contentType AIContentType @default(CHARACTER)

  // AI generation metadata
  generationTool   String // e.g. "Midjourney v6", "Stable Diffusion XL", "DALL-E 3"
  generationPrompt String?   @db.Text
  generationDate   DateTime?
  modelVersion     String? // e.g. "SDXL 1.0"
  cfgScale         Float? // Diffusion params
  seed             String?
  sampler          String?

  // File URLs
  originalFileUrl String?
  thumbnailUrl    String?
  fileSize        Int? // bytes
  mimeType        String?

  // Content hash
  contentHash String? @unique // SHA-256 of original file

  // IPFS storage
  ipfsCid String?
  ipfsUrl String?

  // Tags
  tags String[] @default([])

  // Rights metadata
  copyrightNotice  String?  @db.Text
  licenseScope     String[] @default([]) // e.g. ["commercial", "editorial"]
  isPublicDomain   Boolean  @default(false)
  thirdPartyRights Boolean  @default(false) // 是否有第三方权利

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  ipRegistrations IPRegistration[]

  @@index([ownerId])
  @@index([contentType])
  @@index([contentHash])
}

// IPRegistration: Blockchain copyright certificate
model IPRegistration {
  id String @id @default(cuid())

  aiContentId String
  aiContent   AIContent @relation(fields: [aiContentId], references: [id])

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Registration metadata
  title         String
  description   String? @db.Text
  certificateNo String  @unique // 证书编号 PP-IP-YYYYMMDD-XXXX

  // Certificate type
  certificateType CertificateType @default(OWNERSHIP)

  // Rights declared
  rightsDeclared   String[] @default([]) // e.g. ["reproduction", "distribution", "public_display"]
  territorialScope String   @default("global")
  exclusivity      Boolean  @default(false)
  usageDuration    Int? // 天数，null = 永久

  // Blockchain certification
  blockchainNetwork  String  @default("sepolia")
  blockchainTxHash   String? @unique
  blockchainBlockNum Int?
  contractAddress    String?

  // IPFS
  certificateIpfsCid String?
  metadataIpfsCid    String?

  // Certificate fields
  certifiedAt DateTime?
  expiresAt   DateTime?
  status      IPRegistrationStatus @default(DRAFT)

  // Originality declaration
  originalityDeclaration String? @db.Text
  generationToolConfirm  Boolean @default(false) // 确认使用了该AI工具

  // Third-party IP clearance
  thirdPartyClearance Boolean  @default(false)
  thirdPartyRefs      String[] @default([])

  // Revision history
  version       Int     @default(1)
  previousRegId String?

  // Additional metadata
  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([aiContentId])
  @@index([ownerId])
  @@index([status])
  @@index([certificateNo])
}

// ============================================================
// ContactSubmission — 联系表单提交
// ============================================================

enum ContactType {
  GENERAL // 普通联系表单
  ENTERPRISE // 企业入驻咨询
}

enum ContactStatus {
  NEW // 新提交
  READ // 已读
  PROCESSING // 处理中
  REPLIED // 已回复
  RESOLVED // 已解决
  CLOSED // 已关闭
}

model ContactSubmission {
  id String @id @default(cuid())

  type ContactType @default(GENERAL)

  // 基本信息
  name    String
  email   String
  company String?

  // 留言内容
  subject String?
  message String  @db.Text

  // 企业入驻额外字段
  enterpriseName String? // 企业名称
  intendedUse    String? // 用途说明 @db.Text
  expectedScale  String? // 预期规模
  contactPhone   String? // 联系电话

  // 状态管理
  status     ContactStatus @default(NEW)
  adminNotes String?       @db.Text // 管理员备注
  handledBy  String? // 管理员 ID
  handledAt  DateTime?

  // 邮件通知状态
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  emailError  String?

  // 管理员处理时更新的字段
  repliedAt      DateTime?
  repliedMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}
